    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force-3d": "3.0.6",
    "lucide-react": "^0.487.0",
    "monaco-editor": "0.52.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "recharts": "^2.15.3",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.2.0",
    "three": "~0.172.0",
    "umap-js": "^1.4.0",
    "zustand": "^5.0.5"
