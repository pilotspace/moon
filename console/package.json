{
  "name": "moon-console",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:integration": "playwright test tests/e2e/integration.spec.ts",
    "test:benchmarks": "playwright test tests/e2e/benchmarks.spec.ts",
    "ci:test": "pnpm test && pnpm test:e2e"
  },
  "dependencies": {
